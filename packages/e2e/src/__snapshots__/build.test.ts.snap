    - widgets:
        - label:
            x: 10
            y: 10
            text: !lambda "return espcompose::memo_0.get().c_str();"
            id: rw_ref1
binary_sensor:
  platform: homeassistant
  id: ha_light_kitchen_floods
  entity_id: light.kitchen_floods
  trigger_on_initial_state: true
  on_state:
    - lambda: !lambda "espcompose::sig_ha_light_kitchen_floods.set(x);
        espcompose::Scheduler::instance().flush();"
sensor:
  - platform: homeassistant
    id: ha_light_kitchen_floods_brightness
    entity_id: light.kitchen_floods
    attribute: brightness
    on_value:
      - lambda: !lambda "espcompose::sig_ha_light_kitchen_floods_brightness.set(x);
          espcompose::Scheduler::instance().flush();"
  - platform: homeassistant
    id: ha_sensor_temp_inside
    entity_id: sensor.temp_inside
    on_value:
      - lambda: !lambda "espcompose::sig_ha_sensor_temp_inside.set(x);
          espcompose::Scheduler::instance().flush();"
"
`;

