exports[`ESPHome Compose Build > reactive-device 1`] = `
"esphome:
  name: reactive-device
  comment: Local ref reactive binding demo
  includes:
    - espcompose_bindings.h
    - espcompose_reactive.h
  on_boot:
    priority: -10
    then:
      - lambda: espcompose::setup();
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: HomeWifi
  password: s3cr3t!!
api:
logger:
  level: DEBUG
sensor:
  id: r_ref0
  platform: internal_temperature
  name: ESP Temperature
spi:
  clk_pin: 18
  mosi_pin: 23
display:
  id: r_ref1
  platform: ili9xxx
  model: ILI9341
  invert_colors: false
  cs_pin: 5
  dc_pin: 27
  reset_pin: 33
lvgl:
  displays:
    - r_ref1
  pages:
    - widgets:
        - label:
            x: 10
            y: 10
            text: !lambda "return id(r_ref0).state;"
            id: rw_ref2
        - button:
            x: 10
            y: 50
            width: 120
            height: 50
            on_release:
              - homeassistant.action:
                  action: switch.toggle
                  data:
                    entity_id: switch.space_heater
            widgets:
              - label:
                  text: Heater
                  align: CENTER
        - slider:
            x: 10
            y: 120
            width: 200
            indicator:
              bg_opa: !lambda "return espcompose::memo_0.get().c_str();"
            id: rw_ref3
        - button:
            x: 10
            y: 160
            pressed:
              bg_opa: !lambda "return espcompose::memo_1.get().c_str();"
            widgets:
              - label:
                  text: Styled
                  align: CENTER
            id: rw_ref4
        - slider:
            x: 10
            y: 210
            width: 200
            indicator:
              pressed:
                bg_opa: !lambda "return espcompose::memo_2.get().c_str();"
            id: rw_ref5
binary_sensor:
  platform: homeassistant
  id: ha_switch_space_heater
  entity_id: switch.space_heater
  trigger_on_initial_state: true
  on_state:
    - lambda: !lambda "espcompose::sig_ha_switch_space_heater.set(x);
        espcompose::Scheduler::instance().flush();"
"
`;

exports[`ESPHome Compose Build > script-device 1`] = `
"esphome:
  name: script-device
  comment: Device using action tree authoring
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: HomeWifi
  password: s3cr3t!!
api:
logger:
  level: INFO
binary_sensor:
  platform: gpio
  pin: 4
  name: Button
  on_press:
    - script.execute:
        id: greet
    - script.wait:
        id: greet
  on_release:
    - delay: 100ms
script:
  - id: greet
    then:
      - logger.log: Hello from ESPCompose!
      - delay: 500ms
"
`;

