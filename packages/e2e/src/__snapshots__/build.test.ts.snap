exports[`ESPHome Compose Build > reactive-device 1`] = `
"esphome:
  name: reactive-device
  comment: Local ref reactive binding demo
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: HomeWifi
  password: s3cr3t!!
api:
logger:
  level: DEBUG
sensor:
  id: r_ref0
  platform: internal_temperature
  name: ESP Temperature
  on_value:
    lvgl.label.update:
      id: rw_ref1
      text: !lambda "return x;"
spi:
  clk_pin: 18
  mosi_pin: 23
display:
  id: r_ref2
  platform: ili9xxx
  model: ILI9341
  invert_colors: false
  cs_pin: 5
  dc_pin: 27
  reset_pin: 33
lvgl:
  displays:
    - r_ref2
  pages:
    - widgets:
        - label:
            x: 10
            y: 10
            text: !lambda "return id(r_ref0).state;"
            id: rw_ref1
        - button:
            x: 10
            y: 50
            width: 120
            height: 50
            on_release:
              - homeassistant.action:
                  action: switch.toggle
                  data:
                    entity_id: switch.space_heater
            widgets:
              - label:
                  text: Heater
                  align: CENTER
binary_sensor:
  platform: homeassistant
  id: ha_switch_space_heater
  entity_id: switch.space_heater
  trigger_on_initial_state: true
"
`;

exports[`ESPHome Compose Build > script-device 1`] = `
"esphome:
  name: script-device
  comment: Device using function-as-script authoring
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: HomeWifi
  password: s3cr3t!!
api:
logger:
  level: INFO
binary_sensor:
  platform: gpio
  pin: 4
  name: Button
  on_press:
    - script.execute: greet
  on_release:
    - delay: 100ms
script:
  - id: greet
    then:
      - logger.log: Hello from ESPCompose!
      - delay: 500ms
"
`;

