exports[`ESPHome Compose Build > dashboard-device 1`] = `
"esphome:
  name: living-room-dashboard
  friendly_name: Living Room Dashboard
  comment: A custom Home Assistant dashboard.
  min_version: 2026.1.0
esp32:
  variant: ESP32P4
  flash_size: 32MB
  cpu_frequency: 360MHZ
  framework:
    type: esp-idf
    version: latest
    advanced:
      enable_idf_experimental_features: true
esp32_hosted:
  variant: ESP32C6
  reset_pin: 54
  cmd_pin: 19
  clk_pin: 18
  d0_pin: 14
  d1_pin: 15
  d2_pin: 16
  d3_pin: 17
  active_high: true
psram:
  mode: hex
  speed: 200MHz
preferences:
  flash_write_interval: 5min
esp_ldo:
  voltage: 2.5V
  channel: "3"
i2c:
  id: r_ref0
  sda: 7
  scl: 8
  frequency: 400kHz
  scan: true
touchscreen:
  platform: gt911
  i2c_id: r_ref0
  display: r_ref1
  update_interval: 50ms
  transform:
    swap_xy: true
    mirror_x: true
    mirror_y: false
output:
  id: r_ref2
  platform: ledc
  pin: 26
  frequency: 1000Hz
light:
  platform: monochromatic
  output: r_ref2
  name: Display Backlight
  icon: mdi:lightbulb-on
  restore_mode: ALWAYS_ON
  default_transition_length:
    milliseconds: 250
display:
  id: r_ref1
  platform: mipi_dsi
  model: WAVESHARE-P4-NANO-10.1
  rotation: 270
i2s_audio:
  id: r_ref3
  i2s_mclk_pin: 13
  i2s_lrclk_pin: 10
  i2s_bclk_pin: 12
audio_dac:
  platform: es8311
  i2c_id: r_ref0
  address: 24
audio_adc:
  platform: es7210
  i2c_id: r_ref0
  address: 64
microphone:
  platform: i2s_audio
  i2s_audio_id: r_ref3
  i2s_din_pin: 11
  sample_rate: 16000
  bits_per_sample: 16bit
  adc_type: external
speaker:
  - id: r_ref4
    platform: i2s_audio
    i2s_audio_id: r_ref3
    i2s_dout_pin: 9
    dac_type: external
    channel: mono
    buffer_duration: 100ms
    bits_per_sample: 16bit
    sample_rate: 48000
  - platform: mixer
    output_speaker: r_ref4
    source_speakers:
      - id: r_ref5
        timeout: never
      - id: r_ref6
        timeout: never
  - id: r_ref7
    platform: resampler
    output_speaker: r_ref5
    sample_rate: 48000
    bits_per_sample: 16
  - platform: resampler
    output_speaker: r_ref6
    sample_rate: 48000
    bits_per_sample: 16
rtttl:
  speaker: r_ref7
switch:
  platform: gpio
  pin: 53
  name: Speaker Enable
  icon: mdi:speaker
  entity_category: config
  restore_mode: RESTORE_DEFAULT_ON
wifi:
  networks:
    - ssid: HomeWifi
      password: s3cr3t!!
  power_save_mode: NONE
  fast_connect: true
  ap:
    password: password1234
api:
captive_portal:
web_server:
  port: 80
  version: "3"
ota:
  platform: esphome
logger:
  level: DEBUG
  hardware_uart: UART0
  logs:
    lvgl: INFO
binary_sensor:
  - platform: homeassistant
    name: Kitchen Floods
    entity_id: light.kitchen_floods
    trigger_on_initial_state: true
  - platform: homeassistant
    name: Living Room Light
    entity_id: light.living_room
    trigger_on_initial_state: true
  - platform: homeassistant
    name: Front Door
    entity_id: binary_sensor.front_door_sensor_window_door_is_open
    trigger_on_initial_state: true
  - platform: homeassistant
    name: Back Door
    entity_id: binary_sensor.back_door_sensor_window_door_is_open_2
    trigger_on_initial_state: true
  - platform: homeassistant
    name: Living Room Motion
    entity_id: binary_sensor.living_room_motion_sensor_motion_detection
    trigger_on_initial_state: true
lvgl:
  displays:
    - r_ref1
script:
  - id: play_click_sound
    then:
      - logger.log: Click sound disabled for testing
"
`;

exports[`ESPHome Compose Build > design-system-device 1`] = `
"esphome:
  name: design-system-device
  comment: Design system demo
  includes:
    - espcompose_bindings.h
    - espcompose_reactive.h
  on_boot:
    priority: -10
    then:
      - lambda: espcompose::setup();
  platformio_options:
    build_flags:
      - -DLV_FONT_MONTSERRAT_16=1
      - -DLV_FONT_MONTSERRAT_20=1
      - -DLV_FONT_MONTSERRAT_28=1
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: HomeWifi
  password: s3cr3t!!
api:
logger:
  level: DEBUG
spi:
  clk_pin: 18
  mosi_pin: 23
display:
  id: r_ref0
  platform: ili9xxx
  model: ILI9341
  invert_colors: false
  data_rate: 40MHz
  cs_pin: 5
  dc_pin: 27
  reset_pin: 33
lvgl:
  displays:
    - r_ref0
  pages:
    - bg_color: !lambda "return espcompose::thm_colors_background.get();"
      border_width: 0
      pad_all: !lambda "return espcompose::thm_spacing_lg.get();"
      scrollbar_mode: 'OFF'
      widgets:
        - obj:
            width: 100%
            height: SIZE_CONTENT
            bg_opa: TRANSP
            border_width: 0
            scrollbar_mode: 'OFF'
            layout:
              type: flex
              flex_flow: COLUMN
            widgets:
              - label:
                  text_color: !lambda "return espcompose::thm_colors_textPrimary.get();"
                  text_font: !lambda "return espcompose::memo_0.get();"
                  text: Smart Home
                  id: rw_ref1
              - obj:
                  bg_color: !lambda "return espcompose::thm_colors_surfaceAlt.get();"
                  pad_all: !lambda "return espcompose::thm_spacing_md.get();"
                  radius: !lambda "return espcompose::thm_radii_md.get();"
                  border_width: 0
                  width: 100%
                  height: SIZE_CONTENT
                  scrollbar_mode: 'OFF'
                  layout:
                    type: flex
                    flex_flow: COLUMN
                  widgets:
                    - label:
                        text_color: !lambda "return espcompose::thm_colors_textPrimary.get();"
                        text_font: !lambda "return espcompose::memo_1.get();"
                        text: Living Room
                        id: rw_ref2
                    - obj:
                        bg_opa: TRANSP
                        width: 100%
                        height: SIZE_CONTENT
                        layout:
                          type: flex
                          flex_flow: COLUMN
                        widgets:
                          - label:
                              text_color: !lambda "return espcompose::thm_colors_textPrimary.get();"
                              text_font: !lambda "return espcompose::memo_2.get();"
                              text: Brightness
                              id: rw_ref3
                          - slider:
                              min_value: 0
                              max_value: 255
                    - obj:
                        bg_opa: TRANSP
                        width: 100%
                        height: SIZE_CONTENT
                        layout:
                          type: flex
                          flex_flow: ROW
                          flex_align_main: SPACE_BETWEEN
                          flex_align_cross: CENTER
                        widgets:
                          - label:
                              text_color: !lambda "return espcompose::thm_colors_textPrimary.get();"
                              text_font: !lambda "return espcompose::memo_3.get();"
                              text: Power
                              id: rw_ref4
                          - switch: {}
                  id: rw_ref5
              - obj:
                  width: 100%
                  height: SIZE_CONTENT
                  bg_opa: TRANSP
                  border_width: 0
                  scrollbar_mode: 'OFF'
                  layout:
                    type: flex
                    flex_flow: ROW
                    flex_align_main: SPACE_BETWEEN
                  widgets:
                    - button:
                        bg_color: !lambda "return espcompose::thm_colors_success_bg.get();"
                        border_width: 0
                        width: !lambda "return espcompose::memo_5.get();"
                        height: !lambda "return espcompose::thm_sizes_sm_height.get();"
                        pressed:
                          bg_color: !lambda "return espcompose::thm_colors_success_bgPressed.get();"
                        widgets:
                          - label:
                              text: Turn On
                              text_color: !lambda "return espcompose::thm_colors_success_text.get();"
                              text_font: !lambda "return espcompose::memo_4.get();"
                              align: CENTER
                              id: rw_ref6
                        id: rw_ref7
                    - button:
                        bg_opa: TRANSP
                        border_color: !lambda "return espcompose::thm_colors_danger_bg.get();"
                        border_width: 2
                        width: !lambda "return espcompose::memo_7.get();"
                        height: !lambda "return espcompose::thm_sizes_sm_height.get();"
                        pressed:
                          bg_color: !lambda "return espcompose::thm_colors_danger_bg.get();"
                          bg_opa: COVER
                        widgets:
                          - label:
                              text: Turn Off
                              text_color: !lambda "return espcompose::thm_colors_danger_bg.get();"
                              text_font: !lambda "return espcompose::memo_6.get();"
                              align: CENTER
                              id: rw_ref8
                        id: rw_ref9
      id: rw_ref10
"
`;

exports[`ESPHome Compose Build > device-script-device 1`] = `
"esphome:
  name: device-script-demo
  comment: Device script demo
esp32:
  board: esp32dev
  framework:
    type: arduino
wifi:
  ssid: TestNet
  password: testpass
api:
logger:
binary_sensor:
  platform: gpio
  pin: 4
  name: Button
  on_press:
    - script.execute:
        id: blink
    - script.wait:
        id: blink
  on_release:
    - script.execute:
        id: start_up
    - script.wait:
        id: start_up
script:
  - id: blink
    then:
      - logger.log: Starting blink sequence
      - delay: 1000ms
      - logger.log: Blink done
  - id: start_up
    then:
      - logger.log:
          format: Device booting up
          level: INFO
      - delay: 2000ms
      - logger.log: Boot complete
"
`;

