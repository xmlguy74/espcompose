exports[`ESPHome Compose Build > ha-binding-device 1`] = `
"esphome:
  name: ha-binding-device
  comment: HA entity binding demo
  includes:
    - espcompose_bindings.h
    - espcompose_reactive.h
  on_boot:
    priority: -10
    then:
      - lambda: espcompose::setup();
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: HomeWifi
  password: s3cr3t!!
api:
logger:
  level: DEBUG
spi:
  clk_pin: 18
  mosi_pin: 23
display:
  id: r_ref0
  platform: ili9xxx
  model: ILI9341
  invert_colors: false
  cs_pin: 5
  dc_pin: 27
  reset_pin: 33
lvgl:
  displays:
    - r_ref0
  pages:
    - widgets:
        - label:
            x: 10
            y: 10
            text: !lambda "return std::string(id(ha_light_kitchen_floods).state ? \\"on\\" :
              \\"off\\");"
            id: rw_ref1
        - button:
            x: 10
            y: 40
            width: 120
            height: 50
            on_release:
              - homeassistant.action:
                  action: light.toggle
                  data:
                    entity_id: light.kitchen_floods
            widgets:
              - label:
                  text: Toggle
                  align: CENTER
        - label:
            x: 10
            y: 100
            text: !lambda "return to_string(id(ha_sensor_living_room_temperature).state);"
            id: rw_ref2
binary_sensor:
  platform: homeassistant
  id: ha_light_kitchen_floods
  entity_id: light.kitchen_floods
  trigger_on_initial_state: true
  on_state:
    - lambda: !lambda "espcompose::sig_ha_light_kitchen_floods.set(x);
        espcompose::Scheduler::instance().flush();"
sensor:
  - platform: homeassistant
    id: ha_light_kitchen_floods_brightness
    entity_id: light.kitchen_floods
    attribute: brightness
    on_value:
      - lambda: !lambda "espcompose::sig_ha_light_kitchen_floods_brightness.set(x);
          espcompose::Scheduler::instance().flush();"
  - platform: homeassistant
    id: ha_sensor_living_room_temperature
    entity_id: sensor.living_room_temperature
    on_value:
      - lambda: !lambda "espcompose::sig_ha_sensor_living_room_temperature.set(x);
          espcompose::Scheduler::instance().flush();"
"
`;

