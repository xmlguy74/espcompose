{
  "name": "@espcompose/compose-target-esphome",
  "version": "0.0.1",
  "description": "ESPHome Compose — YAML/C++ firmware target backend",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external @espcompose/core --external yaml",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "license": "MIT",
  "dependencies": {
    "@espcompose/core": "workspace:*",
    "yaml": "catalog:",
    "which": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/which": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
