{
  "name": "@esphome/compose-cli",
  "version": "0.2.0",
  "description": "ESPHome Compose CLI - Command-line tools for building ESPHome Compose projects",
  "bin": {
    "espcompose": "bin/espcompose.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format cjs --dts --external eslint --external @esphome/compose-eslint --external typescript-eslint",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "test": "echo \"No tests yet\""
  },
  "keywords": [
    "esphome",
    "typescript",
    "cli",
    "build-tool"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xmlguy74/espcompose.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@esphome/compose": "workspace:*",
    "@esphome/compose-eslint": "workspace:*",
    "commander": "catalog:",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "which": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/which": "catalog:",
    "tsup": "catalog:"
  }
}
