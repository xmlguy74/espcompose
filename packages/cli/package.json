{
  "name": "@esphome/compose-cli",
  "version": "0.4.0",
  "description": "ESPHome Compose CLI - Command-line tools for building ESPHome Compose projects",
  "bin": {
    "espcompose": "bin/espcompose.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format cjs --dts --external eslint --external @esphome/compose-eslint --external typescript-eslint",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "keywords": [
    "esphome",
    "typescript",
    "cli",
    "build-tool"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xmlguy74/espcompose.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@esphome/compose": "workspace:*",
    "@esphome/compose-eslint": "workspace:*",
    "commander": "catalog:",
    "esbuild": "catalog:",
    "handlebars": "^4.7.8",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "which": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/which": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
