{
  "name": "@esphome/compose",
  "version": "0.4.0",
  "description": "ESPHome Compose SDK - TypeScript framework for generating ESPHome YAML",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.mjs",
      "require": "./dist/jsx-runtime.js"
    },
    "./tsconfig.sdk.json": "./tsconfig.sdk.json"
  },
  "files": [
    "dist",
    "tsconfig.sdk.json"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/jsx-runtime.ts --format cjs,esm --dts --clean --tsconfig tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "keywords": [
    "esphome",
    "typescript",
    "yaml",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xmlguy74/espcompose.git",
    "directory": "packages/sdk"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "yaml": "catalog:"
  },
  "devDependencies": {
    "typescript-eslint": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
