{
  "name": "@esphome/compose-compiler",
  "version": "0.0.5",
  "private": true,
  "description": "ESPHome Compose Compiler - Bundles and executes TSX component trees into ESPHome YAML",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "test": "echo \"No tests yet\""
  },
  "keywords": [
    "esphome",
    "typescript",
    "compiler",
    "yaml"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xmlguy74/espcompose.git",
    "directory": "packages/compiler"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@esphome/compose": "workspace:*",
    "@esphome/compose-eslint": "workspace:*",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "which": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/which": "catalog:",
    "tsup": "catalog:"
  }
}
