{
  "name": "@esphome/compose-ui",
  "version": "0.1.0",
  "description": "LVGL Design System components for ESPHome Compose",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.json",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [
    "esphome",
    "lvgl",
    "ui",
    "design-system"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xmlguy74/espcompose.git",
    "directory": "packages/ui"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@esphome/compose": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "rimraf": "catalog:",
    "vitest": "catalog:"
  }
}
